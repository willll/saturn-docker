+ *	ҒysynopsisҒz														*
+ *																		*
+ *		#include	"per_x.h"											*
+ *																		*
+ *		trigger = PER_GetTrigger( device );								*
+ *																		*
+ *		ғfғoғCғXӮМҺн—ЮӮЙүһӮ¶ӮДғgғҠғKҸо•сӮр“ҫӮЬӮ·ҒB						*
+ *																		*
+ *		PER_SetTriggerHandler() ӮЙӮжӮБӮД“oҳ^ӮіӮкӮДӮўӮйӮhӮcӮрҺқӮВғfғo	*
+ *		ғCғXӮ©ӮзғgғҠғKҸо•сӮрҺжӮиҸoӮ·ӮЙӮНҒA“ҜӮ¶Ӯӯ PER_SetTriggerHandler()*
+ *		ӮЙӮжӮБӮД“oҳ^ӮіӮкӮДӮўӮйҠЦҗ”Ғiғnғ“ғhғүҒjӮр—pӮўӮЬӮ·ҒBӮ»ӮӨӮўӮБӮҪ	*
+ *		ӮаӮМӮӘӮИӮўҸкҚҮӮЙӮНҒAғfғtғHғӢғgӮЕ—pҲУӮіӮкӮДӮўӮйҠЦҗ”Ғiғnғ“ғhғүҒj	*
+ *		Ӯр—pӮўӮЬӮ·ҒBӮұӮМҸкҚҮҒA—\ӮЯ‘ОүһӮөӮДӮўӮй“ь—НғyғҠғtғFғүғӢӮНүәӢL	*
+ *		ӮМӮаӮМӮҫӮҜӮЕӮ·ӮМӮЕҒAӮ»ӮкҲИҠOӮМ“ь—НғyғҠғtғFғүғӢӮ©ӮзғgғҠғKҸо•с	*
+ *		Ӯр“ҫӮҪӮўҸкҚҮӮЙӮНҒAPER_SetTriggerHandler() ӮрҺg—pӮөӮДӮӯӮҫӮіӮўҒB	*
+ *																		*
+ *		ғfғtғHғӢғgӮЕ‘ОүһӮөӮДӮўӮй“ь—НғyғҠғtғFғүғӢ						*
+ *		ғfғWғ^ғӢғfғoғCғX												*
+ *			ғTғ^Ғ[ғ“ғyғҠғtғFғүғӢӮhӮcӮЖӮөӮД 0x02 - 0x0f Ӯр•ФӮ·ӮаӮМ		*
+ *		ғAғiғҚғOғfғoғCғX												*
+ *			ғTғ^Ғ[ғ“ғyғҠғtғFғүғӢӮhӮcӮЖӮөӮД 0x12 - 0x1f Ӯр•ФӮ·ӮаӮМ		*
+ *		ғ|ғCғ“ғeғBғ“ғOғfғoғCғX											*
+ *			ғTғ^Ғ[ғ“ғyғҠғtғFғүғӢӮhӮcӮЖӮөӮД 0x22 - 0x2f Ӯр•ФӮ·ӮаӮМ		*
+ *		ғLҒ[ғ{Ғ[ғhғfғoғCғX												*
+ *			ғTғ^Ғ[ғ“ғyғҠғtғFғүғӢӮhӮcӮЖӮөӮД 0x33 - 0x3f Ӯр•ФӮ·ӮаӮМ		*
+ *		ғҒғKғhғүғCғu—pӮRӮaғpғbғh										*
+ *			ғTғ^Ғ[ғ“ғyғҠғtғFғүғӢӮhӮcӮЖӮөӮД 0xe1 Ӯр•ФӮ·ӮаӮМ				*
+ *		ғҒғKғhғүғCғu—pӮUӮaғpғbғh										*
+ *			ғTғ^Ғ[ғ“ғyғҠғtғFғүғӢӮhӮcӮЖӮөӮД 0xe2 Ӯр•ФӮ·ӮаӮМ				*
+ *		ғҒғKғhғүғCғu—pғ}ғEғX											*
+ *			ғTғ^Ғ[ғ“ғyғҠғtғFғүғӢӮhӮcӮЖӮөӮД 0xe3 Ӯр•ФӮ·ӮаӮМ				*
+ *																		*
+ *																		*
+ *	ҒyparametersҒz														*
+ *																		*
+ *		const SysDevice	*device;										*
+ *																		*
+ *		ғfғoғCғXҸо•с													*
+ *																		*
+ *																		*
+ *	Ғyreturn valueҒz													*
+ *																		*
+ *		trigger_t	trigger;											*
+ *																		*
+ *		ғgғҠғKҸо•сӮр•ФӮөӮЬӮ·ҒB											*
+ *																		*
+ *																		*
+ *	Ғyinfluence/reference objectsҒz										*
+ *																		*
+ *		ӮИӮө															*
+ *																		*
+ *																		*
+ ************************************************************************/
+ trigger_t	PER_GetTrigger( const SysDevice	*this ){
+ 	trigger_t	trigger = 0;
+ 	
+ 	if( this != NULL ){
+ 		int					id = PER_GetID( this );
+ 		trigger_handler_t	handler = PER_GetTriggerHandler( id );
+ 		
+ 		if( handler != NULL )
+ 			trigger = handler( this );
+ 	}
+ 	
+ 	return	trigger;
+ }
+ /*@*/
+ /************************************************************************
+ *																		*
+ *	ҒysynopsisҒz														*
+ *																		*
+ *		#include	"per_x.h"											*
+ *																		*
+ *		edge = PER_GetEdge( t1, t2 );									*
+ *																		*
+ *		ғgғҠғKӮМғGғbғWҸо•сӮр“ҫӮЬӮ·ҒB									*
+ *																		*
+ *		ғGғbғWҸо•сӮЖӮН <t1> ӮЖ <t2> ӮМӮQӮВӮМғ^ғCғ~ғ“ғOӮМӮ ӮўӮҫӮЕ•Пү»	*
+ *		ӮөӮҪғgғҠғKӮМҸо•сӮМӮұӮЖӮрӮўӮўӮЬӮ·ҒB								*
+ *																		*
+ *																		*
+ *	ҒyparametersҒz														*
+ *																		*
+ *		trigger_t	t1;													*
+ *		trigger_t	t2;													*
+ *																		*
+ *		<t1> ӮЖ <t2> ӮНғgғҠғKҸо•сҒB										*
+ *		<t1> ӮЖ <t2> ӮМҺһҠФ“IӮИҸҮҸҳӮН–вӮўӮЬӮ№ӮсҒB						*
+ *																		*
+ *																		*
+ *	Ғyreturn valueҒz													*
+ *																		*
+ *		trigger_t	edge;												*
+ *																		*
+ *		ғgғҠғKӮМғGғbғWҸо•сӮр•ФӮөӮЬӮ·ҒB									*
+ *																		*
+ *																		*
+ *	Ғyinfluence/reference objectsҒz										*
+ *																		*
+ *		ӮИӮө															*
+ *																		*
+ *																		*
+ ************************************************************************/
+ trigger_t	PER_GetEdge( trigger_t	t1, trigger_t	t2 ){
+ 	return	( trigger_t )( t1 ^ t2 );
+ }
+ /*@*/
+ /************************************************************************
+ *																		*
+ *	ҒysynopsisҒz														*
+ *																		*
+ *		#include	"per_x.h"											*
+ *																		*
+ *		edge = PER_GetPressEdge( prev, current );						*
+ *																		*
+ *		ғgғҠғKӮМғvғҢғXғGғbғWҒiүҹүәғGғbғWҒjҸо•сӮр“ҫӮЬӮ·ҒB				*
+ *																		*
+ *		ғvғҢғXғGғbғWҸо•сӮЖӮН <prev> ӮЖ <current> ӮМӮQӮВӮМғ^ғCғ~ғ“ғO		*
+ *		ӮМӮ ӮўӮҫӮЙғҠғҠҒ[ғXҸу‘ФӮ©ӮзғvғҢғXҸу‘ФӮЙ•Пү»ӮөӮҪғgғҠғKӮМҸо•сӮМ	*
+ *		ӮұӮЖӮрӮўӮўӮЬӮ·ҒB												*
+ *																		*
+ *																		*
+ *	ҒyparametersҒz														*
+ *																		*
+ *		trigger_t	prev;												*
+ *		trigger_t	current;											*
+ *																		*
+ *		<prev> ӮЖ <current> ӮНӢӨӮЙғgғҠғKҸо•сҒB							*
+ *		ҺһҠФ“IӮЙҒi <prev> Ғғ <current> ҒjӮЖӮўӮӨҠЦҢWӮрҠъ‘ТӮөӮДӮўӮЬӮ·ҒB	*
+ *																		*
+ *																		*
+ *	Ғyreturn valueҒz													*
+ *																		*
+ *		trigger_t	edge;												*
+ *																		*
+ *		ғgғҠғKӮМғvғҢғXғGғbғWҸо•сӮр•ФӮөӮЬӮ·ҒB							*
+ *																		*
+ *																		*
+ *	Ғyinfluence/reference objectsҒz										*
+ *																		*
+ *		ӮИӮө															*
+ *																		*
+ *																		*
+ ************************************************************************/
+ trigger_t	PER_GetPressEdge( trigger_t	prev, trigger_t	current ){
+ 	trigger_t	edge = PER_GetEdge( prev, current );
+ 	
+ 	return	( trigger_t )( current & edge );
+ }
+ 
+ /*@*/
+ /************************************************************************
+ *																		*
+ *	ҒysynopsisҒz														*
+ *																		*
+ *		#include	"per_x.h"											*
+ *																		*
+ *		edge = PER_GetReleaseEdge( prev, current );						*
+ *																		*
+ *		ғgғҠғKӮМғҠғҠҒ[ғXғGғbғWҒiүр•ъғGғbғWҒjҸо•сӮр“ҫӮЬӮ·ҒB				*
+ *																		*
+ *		ғҠғҠҒ[ғXғGғbғWҸо•сӮЖӮН <prev> ӮЖ <current> ӮМӮQӮВӮМғ^ғCғ~ғ“		*
+ *		ғOӮМӮ ӮўӮҫӮЙғvғҢғXҸу‘ФӮ©ӮзғҠғҠҒ[ғXҸу‘ФӮЙ•Пү»ӮөӮҪғgғҠғKӮМҸо•с	*
+ *		ӮМӮұӮЖӮрӮўӮўӮЬӮ·ҒB												*
+ *																		*
+ *																		*
+ *	ҒyparametersҒz														*
+ *																		*
+ *		trigger_t	prev;												*
+ *		trigger_t	current;											*
+ *																		*
+ *		<prev> ӮЖ <current> ӮНӢӨӮЙғgғҠғKҸо•сҒB							*
+ *		ҺһҠФ“IӮЙҒi <prev> Ғғ <current> ҒjӮЖӮўӮӨҠЦҢWӮрҠъ‘ТӮөӮДӮўӮЬӮ·ҒB	*
+ *																		*
+ *																		*
+ *	Ғyreturn valueҒz													*
+ *																		*
+ *		trigger_t	edge;												*
+ *																		*
+ *		ғgғҠғKӮМғҠғҠҒ[ғXғGғbғWҸо•сӮр•ФӮөӮЬӮ·ҒB							*
+ *																		*
+ *																		*
+ *	Ғyinfluence/reference objectsҒz										*
+ *																		*
+ *		ӮИӮө															*
+ *																		*
+ *																		*
+ ************************************************************************/
+ trigger_t	PER_GetReleaseEdge( trigger_t	prev, trigger_t	current ){
+ 	trigger_t	edge = PER_GetEdge( prev, current );
+ 	
+ 	return	( trigger_t )( ~current & edge );
+ }
+ 
+ #define	ANALOG_ILLEGAL	0xff
+ #define	ANALOG_ORIGIN	0x7f
+ 
+ /*@*/
+ /************************************************************************
+ *																		*
+ *	ҒysynopsisҒz														*
+ *																		*
+ *		#include	"per_x.h"											*
+ *																		*
+ *		PER_GetAnalogXYZ( analog, &x, &y, &z );							*
+ *																		*
+ *		ғAғiғҚғOғfғoғCғXӮ©ӮзӮwӮxӮy•ыҢьӮМӮ`Ғ^ӮcғRғ“ғoҒ[ғ^ӮМҸo—Н’lӮр“ҫ	*
+ *		ӮЬӮ·ҒB															*
+ *																		*
+ *																		*
+ *	ҒyparametersҒz														*
+ *																		*
+ *		const SysDevAnalog	*analog;									*
+ *		int		*x;														*
+ *		int		*y;														*
+ *		int		*z;														*
+ *																		*
+ *		<analog> ӮНғAғiғҚғOғfғoғCғXҸо•сҒB								*
+ *		<x> <y> <z> ӮНӮ»ӮкӮјӮкӮwӮxӮy•ыҢьӮМӮ`Ғ^ӮcғRғ“ғoҒ[ғ^ӮМҸo—Н’lҒB	*
+ *																		*
+ *		<x> <y> <z> ӮЙ NULL Ӯр“nӮ·ӮЖӮ»ӮұӮЙӮНүҪӮа•ФӮіӮкӮЬӮ№ӮсҒB			*
+ *																		*
+ *		<x> ӮЙӮНҒiүEҒj-127 Ғ` +127ҒiҚ¶ҒjӮӘ•ФӮіӮкӮЬӮ·ҒB					*
+ *		<y> ӮЙӮНҒiҸгҒj-127 Ғ` +127ҒiүәҒjӮӘ•ФӮіӮкӮЬӮ·ҒB					*
+ *		<z> ӮЙӮНҒiүәҒj-127 Ғ` +127ҒiҸгҒjӮӘ•ФӮіӮкӮЬӮ·ҒB					*
+ *																		*
+ *																		*
+ *	Ғyreturn valueҒz													*
+ *																		*
+ *		ӮИӮө															*
+ *																		*
+ *																		*
+ *	Ғyinfluence/reference objectsҒz										*
+ *																		*
+ *		ӮИӮө															*
+ *																		*
+ *																		*
+ ************************************************************************/
+ void	PER_GetAnalogXYZ( const SysDevAnalog	*this, int	*x, int	*y, int	*z ){
+ 	int		ax = 0;
+ 	int		ay = 0;
+ 	int		az = 0;
+ 	
+ 	if( this->ax != ANALOG_ILLEGAL )
+ 		ax = ( int )this->ax - ANALOG_ORIGIN;
+ 	if( this->ay != ANALOG_ILLEGAL )
+ 		ay = ( int )this->ay - ANALOG_ORIGIN;
+ 	if( this->az != ANALOG_ILLEGAL )
+ 		az = ( int )this->az - ANALOG_ORIGIN;
+ 	
+ 	if( x != NULL )
+ 		*x = ax;
+ 	if( y != NULL )
+ 		*y = ay;
+ 	if( z != NULL )
+ 		*z = az;
+ }
+ 
+ 
