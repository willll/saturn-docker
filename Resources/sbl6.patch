+ !*****************************************************************************
+ !*
+ !* NAME:  MTH_InitialMatrix()  - Initial Matrix Stack
+ !*
+ !*     void MTH_InitialMatrix(MthMatrixTbl *matrixTbl, Uint16 stackSize,
+ !*						     MthMtrix *matrix)
+ !*
+ !* PARAMETERS :
+ !*
+ !* Б@Б@(1) MthMatrixTbl *matrixTbl - <o> Г}ГgГКГbГNГXГeБ[ГuГЛ
+ !* Б@Б@(2) Uint16       stackSize  - <i> Г}ГgГКГbГNГXГXГ^ГbГNВћН≈СеГGГУГgГКРФ
