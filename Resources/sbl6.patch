+           CLRMAC
+           MAC.L       @r3+,@r4+
+           MAC.L       @r3+,@r4+
+   	  STS	      mach,r1
+ 	  STS	      macl,r0
+ 	  XTRCT	      r1,r0       ! r0 = M11*cos+M12*sin
+           MOV.L       r0,@(20,r6) ! M11 = r0
+           MOV         r8,r4
+           CLRMAC
+           MAC.L       @r9+,@r4+
+           MAC.L       @r9+,@r4+
+   	  STS	      mach,r1
+ 	  STS	      macl,r0
+ 	  XTRCT	      r1,r0       ! r0 = -M11*sin+M12*cos
