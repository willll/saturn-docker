+  	  			LDS.L      	@r15+,mach
+           MOV.L       @r15+,r9
+           MOV.L       @r15+,r10
+           MOV.L       @r15+,r11
+           MOV.L       @r15+,r12
+           MOV.L       @r15+,r13
+           RTS                          ! return r0
+           MOV.L       @r15+,r14
