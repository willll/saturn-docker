+           MAC.L       @r3+,@r4+
+           MAC.L       @r3+,@r4+
+   	  STS	      mach,r1
+ 	  STS	      macl,r0
+ 	  XTRCT	      r1,r0       ! r0 = M10*cos+M11*sin
+           MOV.L       r0,@(16,r6) ! M10 = r0
+           MOV         r8,r4
+           CLRMAC
+           MAC.L       @r9+,@r4+
+           MAC.L       @r9+,@r4+
+   	  STS	      mach,r1
+ 	  STS	      macl,r0
+ 	  XTRCT	      r1,r0       ! r0 = -M10*sin+M11*cos
+           MOV.L       r0,@(20,r6) ! M11 = r0
+ 	  ADD         #8,r15
+ !
+           MOV.L       @(36,r6),r0
+           MOV.L       r0,@-r15   ! Push  M21
+           MOV.L       @(32,r6),r0
+           MOV.L       r0,@-r15   ! Push  M20
+           MOV         r15,r9     ! @r9 = (M20,M21)
+           MOV         r7,r4
+           MOV         r9,r3
+           CLRMAC
+           MAC.L       @r3+,@r4+
+           MAC.L       @r3+,@r4+
+   	  STS	      mach,r1
+ 	  STS	      macl,r0
+ 	  XTRCT	      r1,r0       ! r0 = M20*cos+M21*sin
