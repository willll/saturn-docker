+           MAC.L       @r9+,@r4+
+   	  STS	      mach,r1
+ 	  STS	      macl,r0
+ 	  XTRCT	      r1,r0      ! r0 = -M00*sin+M01*cos
+           MOV.L       r0,@(4,r6) ! M01 = r0
+ 	  ADD         #8,r15
+ !
+           MOV.L       @(20,r6),r0
+           MOV.L       r0,@-r15   ! Push  M11
+           MOV.L       @(16,r6),r0
+           MOV.L       r0,@-r15   ! Push  M10
