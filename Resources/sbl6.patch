+           MOV.L       @(36,r6),r0
+           MOV.L       r0,@-r15   ! Push  M21
+           MOV         r15,r9     ! @r9 = (M21,M22)
+           MOV         r7,r4
+           MOV         r9,r3
+           CLRMAC
+           MAC.L       @r3+,@r4+
+           MAC.L       @r3+,@r4+
+   	  STS	      mach,r1
+ 	  STS	      macl,r0
+ 	  XTRCT	      r1,r0       ! r0 = M21*cos+M22*sin
+           MOV.L       r0,@(36,r6) ! M21 = r0
