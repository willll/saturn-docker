+ !  �ȉ��̃��[�`�����܂ށB
+ !
+ !  _MTH_ComputeNormalVect       -  �@���x�N�^�v�Z�֐�
+ !
+ !----------------------------------------------------------------------------
+           .global     _MTH_ComputeNormVect
+ !
+ .if 1
+ .equ SAVE_r14,0
+ .equ NORMAL_P,4
+ 
+ .equ X,0
+ .equ Y,4
+ .equ Z,8
+ .endif
