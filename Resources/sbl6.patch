+ _MTH_MulMatrix:                 ! function: MTH_MulMatrix
+     	    STS.L       mach,@-r15
+           STS.L       macl,@-r15
+ !---------
+           MOV.L       @(32,r5),r0
+           MOV.L       r0,@-r15      ! Push b20
+           MOV.L       @(16,r5),r0
+           MOV.L       r0,@-r15      ! Push b10
+           MOV.L       @(0,r5),r0
+           MOV.L       r0,@-r15      ! Push b00
+ !
+           MOV         r4,r2         ! r2 = a00
+           MOV         r15,r3        ! r3 = (b00, b10, b20)
